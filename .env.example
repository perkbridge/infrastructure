COMPOSE_PROJECT_NAME=agave-localnet
RPC_PORT=8899
RPC_WEBSOCKET_PORT=8900
FAUCET_PORT=9900
PORTAL_PORT=3000
EXPLORER_PORT=3001
WALLET_APP_PORT=3100
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=local-development-admin
WALLET_API_PORT=8787
# Development only. Change this before creating wallets; changing it later makes existing keys unreadable.
WALLET_MASTER_KEY=local-development-only-key-change-me
# Development-only secret export and server-side transaction signing.
WALLET_PRIVATE_KEY_EXPORT_ENABLED=true
WALLET_TRANSACTION_SIGNING_ENABLED=true
# Keep the old unauthenticated API disabled; authenticated routes are documented in Swagger.
WALLET_LEGACY_API_ENABLED=false
RUST_LOG=info
